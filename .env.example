# ── LLM ────────────────────────────────────────────────────────────────────────
# Option A — Anthropic Claude (default):
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514

# Option B — OpenAI or OpenAI-compatible endpoint:
# LLM_API_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Option C — Groq:
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Dialogflow CX (voice ASR) ──────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
DIALOGFLOW_PROJECT_ID=your-gcp-project-id
DIALOGFLOW_AGENT_ID=your-dialogflow-cx-agent-id
DIALOGFLOW_LOCATION=global

# ── TTS (voice output) ─────────────────────────────────────────────────────────
# TTS_BACKEND=google   # google | gtts | mock (default)
# TTS_LANGUAGE=en-GB

# ── Platform Directory System ──────────────────────────────────────────────────
PLATFORM_DIR_API_BASE_URL=https://platform-directory.example.com/api/v1

# ── SoR_1 (formerly BaNCS) ────────────────────────────────────────────────────
SOR1_API_BASE_URL=https://sor1.example.com/api/v1
SOR1_CLIENT_ID=your-oauth-client-id
SOR1_CLIENT_SECRET=your-oauth-client-secret

# ── RAG / FAQ Knowledge Base ───────────────────────────────────────────────────
# VECTOR_DB_BACKEND=chroma       # chroma | pgvector | mock (default)
# VECTOR_DB_URL=http://localhost:8000
# VECTOR_DB_COLLECTION=faq_docs
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# RAG_TOP_K=5
# RAG_SCORE_THRESHOLD=0.75

# ── Audit Logging ──────────────────────────────────────────────────────────────
# AUDIT_LOG_DESTINATION=stdout   # stdout | file:/path/to/audit.jsonl
AUDIT_LOG_DESTINATION=stdout

# ── Tool Registry ──────────────────────────────────────────────────────────────
TOOL_REGISTRY_PATH=tool_registry.yaml

# ── Behaviour Tuning ───────────────────────────────────────────────────────────
MAX_POLICY_RETRIES=3
LOOP_DETECTION_THRESHOLD=3

# ── Development / Testing Flags ───────────────────────────────────────────────
USE_MOCK_ASR=true           # true = bypass Dialogflow CX
USE_MOCK_POLICY_API=true    # true = use built-in stub data (no real SoR_1 needed)
USE_MOCK_RAG=false           # true = use keyword-match stub FAQ (no vector DB needed)
USE_MOCK_TTS=false           # true = skip TTS synthesis (log text only)
